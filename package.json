{
  "name": "its-just-logic",
  "version": "0.1.6",
  "description": "It's Just Logic — a space territory strategy game",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64"
  },
  "build": {
    "appId": "com.itsjustlogic.game",
    "productName": "It's Just Logic",
    "directories": {
      "output": "release"
    },
    "files": [
      "index.html",
      "main.js",
      "lib/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "publish": {
      "provider": "github",
      "owner": "DrPineapp1e",
      "repo": "its-just-logic"
    }
  },
  "devDependencies": {
    "@electron/packager": "^18.0.0",
    "electron": "^30.0.0",
    "electron-builder": "^26.8.1",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5"
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  }
}
